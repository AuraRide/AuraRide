# =============================================================================
# AuraRide · Caddy 反向代理(运行在 docker compose 的 caddy 容器中)
# =============================================================================
# 容器路径:/etc/caddy/Caddyfile(由 docker-compose.yml 通过 bind mount 注入)
# 静态目录:/srv/auraride/web(由 docker-compose.prod.yml bind mount 自服务器 /var/www/auraride/web)
#
# Caddy 自动:
#   1. 从 Let's Encrypt 申请 SSL(无需配置)
#   2. 每 60 天续期(状态持久到 caddy_data named volume)
#   3. HTTP → HTTPS 跳转
#   4. HTTP/2 + HTTP/3
#   5. gzip + zstd 压缩
#
# upstream 用 docker 内网 hostname(compose service name 即 DNS 名),
# 不再是 localhost:8080(因为 caddy 现在跑在容器里)
# =============================================================================


# -----------------------------------------------------------------------------
# Production: auraride.cn + www.auraride.cn
# -----------------------------------------------------------------------------
auraride.cn, www.auraride.cn {
    handle /api/* {
        reverse_proxy api:8080
    }

    handle /upload/* {
        reverse_proxy api:8080
    }

    # SPA 兜底:其他路径都给 React 的 index.html
    handle {
        root * /srv/auraride/web
        try_files {path} /index.html
        file_server
        encode gzip zstd
    }

    log {
        output file /var/log/caddy/auraride.cn.log {
            roll_size 100mb
            roll_keep 5
        }
        format json
    }
}


# -----------------------------------------------------------------------------
# Staging: staging.auraride.cn(陈娟 + chenzhuowen 看最新 mvp-a)
# -----------------------------------------------------------------------------
staging.auraride.cn {
    handle /api/* {
        # staging 仍打到同一个 api 容器(MVP 阶段无独立 staging api)
        reverse_proxy api:8080
    }

    handle {
        root * /srv/auraride/staging
        try_files {path} /index.html
        file_server
        encode gzip zstd
    }

    log {
        output file /var/log/caddy/staging.auraride.cn.log
    }
}


# -----------------------------------------------------------------------------
# API 独立子域(可选,CORS 严格场景)
# -----------------------------------------------------------------------------
api.auraride.cn {
    reverse_proxy api:8080
    log {
        output file /var/log/caddy/api.auraride.cn.log
    }
}


# -----------------------------------------------------------------------------
# 安全头(applies to all)
# -----------------------------------------------------------------------------
(security_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}
