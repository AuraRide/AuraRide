# AuraRide worker —— 本地开发 env 示例
# 真值在 ../../AuraRide-env/.env.production(加密),systemd 部署时从那里注入。

# 数据库
POSTGRES_URL=postgresql://auraride:CHANGEME@127.0.0.1:5432/auraride

# Redis(dramatiq broker + 预算闸门)
REDIS_URL=redis://127.0.0.1:6379/0

# DashScope 通义千问 VL —— 无 key 时 worker 自动降级到 Pillow 平均色
DASHSCOPE_API_KEY=
DASHSCOPE_VLM_MODEL=qwen-vl-plus

# 腾讯云 COS(读取待染色照片)
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_BUCKET=auraride-photos-1315627382

# 预算闸门(单位:人民币元 / 天)
VLM_DAILY_BUDGET_CNY=20.0
VLM_COST_PER_CALL_CNY=0.015

# 日志
LOG_LEVEL=INFO
LOG_JSON=false
