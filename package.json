{
  "name": "auraride",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @auraride/web dev",
    "build": "pnpm --filter @auraride/web build",
    "preview": "pnpm --filter @auraride/web preview",
    "typecheck": "pnpm -r typecheck",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "env:add-public": "echo 'usage: 直接编辑 ../AuraRide-env/.env.public 然后 cd 过去 commit + push'",
    "env:add-secret": "echo 'usage: pnpm exec dotenvx set MY_KEY=PLACEHOLDER -f ../AuraRide-env/.env.production'"
  },
  "devDependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@dotenvx/dotenvx": "^1.74.2",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.21",
    "debug": "^4.4.3",
    "mermaid": "^11.15.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
